rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Ogni utente legge/scrive solo i propri dati (watchlist ed episodi visti).
    match /users/{userId} {
      match /watchlist/{showId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /watchedEpisodes/{episodeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /movieWatchlist/{movieId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /watchedMovies/{movieId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Commenti per episodio: leggibili da chiunque sia autenticato,
    // scrivibili/cancellabili solo dall'autore del commento.
    match /episodeComments/{episodeId}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
